---
// src/layouts/BaseLayout.astro
export interface Props {
  title: string;
  locale?: string;
}

const { title, locale = 'es' } = Astro.props;
---

<!DOCTYPE html>
<html lang={locale}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link rel="stylesheet" href="/src/styles/global.css">
</head>
<body>
    <slot />
</body>
</html>