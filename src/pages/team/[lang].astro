---
// src/pages/team/[lang].astro
import { t, defaultLocale, locales } from '../../i18n/index';
import { getCollection } from 'astro:content';

// Получаем язык из параметров маршрута
export async function getStaticPaths() {
  return locales.map(locale => ({
    params: { lang: locale },
    props: { locale }
  }));
}

const { locale } = Astro.props;
const tKey = (key: string) => t(locale, key);

// Загружаем команду для текущего языка
const collectionName = `team_${locale}`;
let team = await getCollection(collectionName);    

// Сортируем по полю order (если есть)
team = team.sort((a, b) => {
  const orderA = a.data.order || 999;
  const orderB = b.data.order || 999;
  return orderA - orderB;
});

// Отладка
console.log(`[Team] Current locale: ${locale}`);
console.log(`[Team] Collection name: ${collectionName}`);
console.log(`[Team] Team members count: ${team.length}`);
// Контактные данные
const contactInfo = {
  es: {
    address: "Avenida Gabriel Roca 16, Palma de Mallorca, 07014",
    phone: "+34 677 656 521",
    email: "info@evitax.es",
    schedule: {
      week: "Lunes a Viernes: 9:00 - 18:00",
      saturday: "Sábados: 10:00 - 14:00"
    }
  },
  ru: {
    address: "Авенида Габриэль Рока 16, Пальма-де-Мальорка, 07014",
    phone: "+34 677 656 521",
    email: "info@evitax.es",
    schedule: {
      week: "Понедельник - Пятница: 9:00 - 18:00",
      saturday: "Суббота: 10:00 - 14:00"
    }
  },
  en: {
    address: "Avenida Gabriel Roca 16, Palma de Mallorca, 07014",
    phone: "+34 677 656 521",
    email: "info@evitax.es",
    schedule: {
      week: "Monday - Friday: 9:00 - 18:00",
      saturday: "Saturday: 10:00 - 14:00"
    }
  }
};

const info = contactInfo[locale] || contactInfo.es;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang={locale}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>{tKey('nav.team')} | Evitax </title>
    <link rel="stylesheet" href="/src/styles/global.css">
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="header-content">
                <a href={`/${locale}`} class="logo">
                <span class="logo-icon"><img src="/logo_evi_big.png" alt="EVITAX" style="height: 75px; width: auto;"></span>
                <span class="logo-text">Evitax</span>
                <span class="logo-text">Group</span>
                </a>
                <nav class="nav">
                <a href={`/${locale}`} class={currentPath === `/${locale}` || currentPath === `/${locale}/` ? 'active' : ''}>
                    {tKey('nav.home')}
                </a>
                <a href={`/services/${locale}`} class={currentPath.includes(`/services/${locale}`) ? 'active' : ''}>
                    {tKey('nav.services')}
                </a>
                <a href={`/team/${locale}`} class={currentPath.includes(`/team/${locale}`) ? 'active' : ''}>
                    {tKey('nav.team')}
                </a>
                <a href={`/contacts/${locale}`} class={currentPath.includes(`/contacts/${locale}`) ? 'active' : ''}>
                    {tKey('nav.contacts')}
                </a>
                </nav>
                <div class="language-switcher">
                    <a href="/team/es" class={locale === 'es' ? 'active' : ''}>ES</a>
                    <a href="/team/ru" class={locale === 'ru' ? 'active' : ''}>RU</a>
                    <a href="/team/en" class={locale === 'en' ? 'active' : ''}>EN</a>
                </div>
            </div>
        </div>
    </header>

    <main>
        <section class="section">
            <div class="container">
                <h1 class="section-title">{tKey('nav.team')}</h1>
                
                {team.length === 0 ? (
                    <div class="text-center">
                        <p>
                            {locale === 'es' && 'No hay miembros del equipo disponibles en este momento.'}
                            {locale === 'ru' && 'В данный момент члены команды не добавлены.'}
                            {locale === 'en' && 'No team members available at this time.'}
                        </p>
                        <p>
                            <a href="/admin">
                                {locale === 'es' ? 'Administrar equipo →' : 
                                 locale === 'ru' ? 'Управление командой →' : 
                                 'Manage team →'}
                            </a>
                        </p>
                    </div>
                ) : (
                    <!-- Team Tabs: на мобильных аккордеон, на десктопе сетка -->
                    <div class="team-tabs" id="teamTabs">
                        {team.map((member, index) => (
                            <div class="team-tab-item" data-index={index}>
                                <button class="team-tab-button">
                                    <span class="team-tab-name">{member.data.name}</span>
                                    <span class="team-tab-position">{member.data.position}</span>
                                    <span class="team-tab-icon">▼</span>
                                </button>
                                <div class="team-tab-content">
                                    <!-- Фото -->
                                    {member.data.photo && (
                                        <div class="team-photo-container">
                                            <img 
                                                src={member.data.photo} 
                                                alt={member.data.name}
                                                class="team-photo"
                                            />
                                        </div>
                                    )}
                                    <!-- Информация -->
                                    <div class="team-info">
                                        <h3 class="team-name">{member.data.name}</h3>
                                        <p class="team-position">{member.data.position}</p>
                                        {member.data.bio && <p class="team-bio">{member.data.bio}</p>}
                                        <div class="team-contacts">
                                            {member.data.email && (
                                                <p>✉️ <a href={`mailto:${member.data.email}`}>{member.data.email}</a></p>
                                            )}
                                            {member.data.phone && (
                                                <p>📞 <a href={`tel:${member.data.phone}`}>{member.data.phone}</a></p>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                )}
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>EVITAX</h3>
                    <p>{info.address}</p>
                    <p>📞 {info.phone}</p>
                    <p>✉️ {info.email}</p>
                </div>
                <div class="footer-section">
                    <h3>{tKey('nav.services')}</h3>
                    <p>✓ {locale === 'es' ? 'Asesoría Contable' : locale === 'ru' ? 'Бухгалтерский консалтинг' : 'Accounting Consulting'}</p>
                    <p>✓ {locale === 'es' ? 'Declaración de Impuestos' : locale === 'ru' ? 'Налоговые декларации' : 'Tax Returns'}</p>
                    <p>✓ {locale === 'es' ? 'Gestión Laboral' : locale === 'ru' ? 'Кадровый учет' : 'HR Management'}</p>
                </div>
                <div class="footer-section">
                    <h3>{locale === 'es' ? 'Horario' : locale === 'ru' ? 'Часы работы' : 'Schedule'}</h3>
                    <p>{info.schedule.week}</p>
                    <p>{info.schedule.saturday}</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 EVITAX. {tKey('footer.rights')}</p>
            </div>
        </div>
    </footer>

<script>
  (function() {
    function initTeamTabs() {
      var buttons = document.querySelectorAll('.team-tab-button');
      
      for (var i = 0; i < buttons.length; i++) {
        buttons[i].onclick = function(e) {
          var tabItem = this.closest('.team-tab-item');
          var isActive = tabItem.classList.contains('active');
          var allTabs = document.querySelectorAll('.team-tab-item');
          
          for (var j = 0; j < allTabs.length; j++) {
            allTabs[j].classList.remove('active');
          }
          
          if (!isActive) {
            tabItem.classList.add('active');
            
            // 🆕 Плавный скролл к началу карточки на мобильных
            if (window.innerWidth < 768) {
              setTimeout(function() {
                var headerHeight = document.querySelector('.header')?.offsetHeight || 80;
                var elementPosition = tabItem.getBoundingClientRect().top;
                var offsetPosition = elementPosition + window.pageYOffset - headerHeight - 10;
                
                window.scrollTo({
                  top: offsetPosition,
                  behavior: 'smooth'
                });
              }, 50);
            }
          }
        };
      }
      
      var firstTab = document.querySelector('.team-tab-item');
      if (firstTab) {
        firstTab.classList.add('active');
      }
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTeamTabs);
    } else {
      initTeamTabs();
    }
  })();
</script>

</body>
</html>