---
// src/pages/services/[lang].astro
import { t, defaultLocale, locales } from '../../i18n/index';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

// Генерация статических путей
export async function getStaticPaths() {
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;
const currentLocale = locales.includes(locale) ? locale : defaultLocale;
const tKey = (key: string) => t(currentLocale, key);

// Загружаем услуги
const collectionName = `services_${currentLocale}`;
const services = await getCollection(collectionName);

// Контактные данные
const contactInfo = {
  es: {
    address: "Avenida Gabriel Roca 16, Palma de Mallorca, 07014",
    phone: "+34 677 656 521",
    email: "info@evitax.es",
    schedule: {
      week: "Lunes a Viernes: 9:00 - 18:00",
      saturday: "Sábados: 10:00 - 14:00"
    }
  },
  ru: {
    address: "Авенида Габриэль Рока 16, Пальма-де-Мальорка, 07014",
    phone: "+34 677 656 521",
    email: "info@evitax.es",
    schedule: {
      week: "Понедельник - Пятница: 9:00 - 18:00",
      saturday: "Суббота: 10:00 - 14:00"
    }
  },
  en: {
    address: "Avenida Gabriel Roca 16, Palma de Mallorca, 07014",
    phone: "+34 677 656 521",
    email: "info@evitax.es",
    schedule: {
      week: "Monday - Friday: 9:00 - 18:00",
      saturday: "Saturday: 10:00 - 14:00"
    }
  }
};

const info = contactInfo[locale] || contactInfo.es;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang={currentLocale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{tKey('nav.services')} | Evitax</title>
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>

<body>
  <header class="header">
    <div class="container">
      <div class="header-content">
                <a href={`/${locale}`} class="logo">
                <span class="logo-icon"><img src="/logo_evi_big.png" alt="EVITAX" style="height: 75px; width: auto;"></span>
                <span class="logo-text">Evitax</span>
                <span class="logo-text">Group</span>
                </a>
                <nav class="nav">
                <a href={`/${locale}`} class={currentPath === `/${locale}` || currentPath === `/${locale}/` ? 'active' : ''}>
                    {tKey('nav.home')}
                </a>
                <a href={`/services/${locale}`} class={currentPath.includes(`/services/${locale}`) ? 'active' : ''}>
                    {tKey('nav.services')}
                </a>
                <a href={`/team/${locale}`} class={currentPath.includes(`/team/${locale}`) ? 'active' : ''}>
                    {tKey('nav.team')}
                </a>
                <a href={`/contacts/${locale}`} class={currentPath.includes(`/contacts/${locale}`) ? 'active' : ''}>
                    {tKey('nav.contacts')}
                </a>
                </nav>
        <div class="language-switcher">
          <a href="/services/es" class={currentLocale === 'es' ? 'active' : ''}>ES</a>
          <a href="/services/ru" class={currentLocale === 'ru' ? 'active' : ''}>RU</a>
          <a href="/services/en" class={currentLocale === 'en' ? 'active' : ''}>EN</a>
        </div>
      </div>
    </div>
  </header>

  <main>
    <section class="section">
      <div class="container">
        <h1 class="section-title">{tKey('nav.services')}</h1>

        {services.length === 0 ? (
          <div class="text-center">
            <p>
              {currentLocale === 'es' && 'No hay servicios disponibles en este momento.'}
              {currentLocale === 'ru' && 'В данный момент услуги не добавлены.'}
              {currentLocale === 'en' && 'No services available at this time.'}
            </p>
            <p><a href="/admin">
              {currentLocale === 'es' ? 'Administrar servicios →' : currentLocale === 'ru' ? 'Управление услугами →' : 'Manage services →'}
            </a></p>
          </div>
        ) : (
          <div class="services-tabs" id="servicesTabs">
            {services.map((service, index) => (
              <div class="tab-item" data-index={index}>
                <button class="tab-button">
                  <span class="tab-title">{service.data.title}</span>
                  {service.data.price && <span class="tab-price">{service.data.price}</span>}
                  <span class="tab-icon">▼</span>
                </button>
                <div class="tab-content">
                  {service.data.image && (
                    <img src={service.data.image} alt={service.data.title} class="tab-image" />
                  )}
                  <div class="tab-description" set:html={marked(service.body)} />
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>EVITAX</h3>
                    <p>{info.address}</p>
                    <p>📞 {info.phone}</p>
                    <p>✉️ {info.email}</p>
                </div>
                <div class="footer-section">
                    <h3>{tKey('nav.services')}</h3>
                    <p>✓ {locale === 'es' ? 'Asesoría Contable' : locale === 'ru' ? 'Бухгалтерский консалтинг' : 'Accounting Consulting'}</p>
                    <p>✓ {locale === 'es' ? 'Declaración de Impuestos' : locale === 'ru' ? 'Налоговые декларации' : 'Tax Returns'}</p>
                    <p>✓ {locale === 'es' ? 'Gestión Laboral' : locale === 'ru' ? 'Кадровый учет' : 'HR Management'}</p>
                </div>
                <div class="footer-section">
                    <h3>{locale === 'es' ? 'Horario' : locale === 'ru' ? 'Часы работы' : 'Schedule'}</h3>
                    <p>{info.schedule.week}</p>
                    <p>{info.schedule.saturday}</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 EVITAX. {tKey('footer.rights')}</p>
            </div>
        </div>
    </footer>


  <!-- Подключаем внешний скрипт для табов -->
  <script>
  (function() {
    function initTabs() {
      var buttons = document.querySelectorAll('.tab-button');
      
      for (var i = 0; i < buttons.length; i++) {
        buttons[i].onclick = function(e) {
          var tabItem = this.closest('.tab-item');
          var isActive = tabItem.classList.contains('active');
          var allTabs = document.querySelectorAll('.tab-item');
          
          for (var j = 0; j < allTabs.length; j++) {
            allTabs[j].classList.remove('active');
          }
          
          if (!isActive) {
            tabItem.classList.add('active');
            
            // 🆕 Плавный скролл к началу карточки на мобильных
            if (window.innerWidth < 768) {
              setTimeout(function() {
                var headerHeight = document.querySelector('.header')?.offsetHeight || 80;
                var elementPosition = tabItem.getBoundingClientRect().top;
                var offsetPosition = elementPosition + window.pageYOffset - headerHeight - 10;
                
                window.scrollTo({
                  top: offsetPosition,
                  behavior: 'smooth'
                });
              }, 50);
            }
          }
        };
      }
      
      var firstTab = document.querySelector('.tab-item');
      if (firstTab) {
        firstTab.classList.add('active');
      }
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initTabs);
    } else {
      initTabs();
    }
  })();
</script>
</body>
</html>