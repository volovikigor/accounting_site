---
// src/pages/services/[lang].astro
import { t, defaultLocale, locales } from '../../i18n/index';
import { getCollection } from 'astro:content';
import { marked } from 'marked';

// Генерация статических путей
export async function getStaticPaths() {
  return locales.map((locale) => ({
    params: { lang: locale },
    props: { locale },
  }));
}

const { locale } = Astro.props;

// fallback
const currentLocale = locales.includes(locale) ? locale : defaultLocale;

const tKey = (key: string) => t(currentLocale, key);

// Загружаем услуги
const collectionName = `services_${currentLocale}`;
const services = await getCollection(collectionName);

// ❗ НИКАКОГО render() — используем напрямую services
console.log(`[Services] Locale: ${currentLocale}`);
console.log(`[Services] Count: ${services.length}`);
---

<!DOCTYPE html>
<html lang={currentLocale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{tKey('nav.services')} | ContabilidadPro</title>
  <link rel="stylesheet" href="/src/styles/global.css" />
</head>

<body>
  <header class="header">
    <div class="container">
      <div class="header-content">
        <a href={`/${currentLocale}`} class="logo">📊 ContabilidadPro</a>

        <nav class="nav">
          <a href={`/${currentLocale}`}>{tKey('nav.home')}</a>
          <a href={`/services/${currentLocale}`}>{tKey('nav.services')}</a>
          <a href={`/team/${currentLocale}`}>{tKey('nav.team')}</a>
          <a href={`/contacts/${currentLocale}`}>{tKey('nav.contacts')}</a>
        </nav>

        <div class="language-switcher">
          <a href="/services/es" class={currentLocale === 'es' ? 'active' : ''}>ES</a>
          <a href="/services/ru" class={currentLocale === 'ru' ? 'active' : ''}>RU</a>
          <a href="/services/en" class={currentLocale === 'en' ? 'active' : ''}>EN</a>
        </div>
      </div>
    </div>
  </header>

  <main>
    <section class="section">
      <div class="container">
        <h1 class="section-title">{tKey('nav.services')}</h1>

        {services.length === 0 ? (
          <div class="text-center">
            <p>
              {currentLocale === 'es' && 'No hay servicios disponibles en este momento.'}
              {currentLocale === 'ru' && 'В данный момент услуги не добавлены.'}
              {currentLocale === 'en' && 'No services available at this time.'}
            </p>

            <p>
              <a href="/admin">
                {currentLocale === 'es'
                  ? 'Administrar servicios →'
                  : currentLocale === 'ru'
                  ? 'Управление услугами →'
                  : 'Manage services →'}
              </a>
            </p>
          </div>
        ) : (
          <div class="services-grid">
            {services.map((service) => (
              <div class="service-card" key={service.id}>
                
                {service.data.image && (
                  <img
                    src={service.data.image}
                    alt={service.data.title}
                    style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px; margin-bottom: 1rem;"
                  />
                )}

                <h3>{service.data.title}</h3>

                {service.data.price && (
                  <div class="service-price">{service.data.price}</div>
                )}

                {/* ✅ Markdown теперь парсится правильно */}
                <div 
                  class="service-description" 
                  set:html={marked(service.body)} 
                />

              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        
        <div class="footer-section">
          <h3>ContabilidadPro</h3>
          <p>{tKey('footer.address')}</p>
          <p>📞 {tKey('footer.phone')}</p>
          <p>✉️ {tKey('footer.email')}</p>
        </div>

        <div class="footer-section">
          <h3>{tKey('nav.services')}</h3>
          <p>✓ {currentLocale === 'es' ? 'Asesoría Contable' : currentLocale === 'ru' ? 'Бухгалтерский консалтинг' : 'Accounting Consulting'}</p>
          <p>✓ {currentLocale === 'es' ? 'Declaración de Impuestos' : currentLocale === 'ru' ? 'Налоговые декларации' : 'Tax Returns'}</p>
          <p>✓ {currentLocale === 'es' ? 'Gestión Laboral' : currentLocale === 'ru' ? 'Кадровый учет' : 'HR Management'}</p>
        </div>

        <div class="footer-section">
          <h3>{currentLocale === 'es' ? 'Horario' : currentLocale === 'ru' ? 'Часы работы' : 'Schedule'}</h3>
          <p>{currentLocale === 'es' ? 'Lunes - Viernes: 9:00 - 18:00' : currentLocale === 'ru' ? 'Пн - Пт: 9:00 - 18:00' : 'Mon - Fri: 9:00 - 18:00'}</p>
          <p>{currentLocale === 'es' ? 'Sábado: 10:00 - 14:00' : currentLocale === 'ru' ? 'Сб: 10:00 - 14:00' : 'Sat: 10:00 - 14:00'}</p>
        </div>

      </div>

      <div class="footer-bottom">
        <p>&copy; 2024 ContabilidadPro. {tKey('footer.rights')}</p>
      </div>
    </div>
  </footer>
</body>
</html>