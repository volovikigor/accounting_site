---
// src/pages/contacts/[lang].astro
import { t, defaultLocale, locales } from '../../i18n/index';

export async function getStaticPaths() {
  return locales.map(locale => ({
    params: { lang: locale },
    props: { locale }
  }));
}

const { locale } = Astro.props;
const tKey = (key: string) => t(locale, key);

// Контактные данные
const contactInfo = {
  es: {
    address: "Avenida Gabriel Roca 16-6, Palma de Mallorca, 07014",
    phone: "+34 677 656 521",
    email: "info@evitax.es",
    schedule: {
      week: "Lunes a Viernes: 9:00 - 18:00",
      saturday: "Sábados: 10:00 - 14:00"
    }
  },
  ru: {
    address: "Авенида Габриэль Рока 16-6, Пальма-де-Мальорка, 07014",
    phone: "+34 677 656 521",
    email: "info@evitax.es",
    schedule: {
      week: "Понедельник - Пятница: 9:00 - 18:00",
      saturday: "Суббота: 10:00 - 14:00"
    }
  },
  en: {
    address: "Avenida Gabriel Roca 16-6, Palma de Mallorca, 07014",
    phone: "+34 677 656 521",
    email: "info@evitax.es",
    schedule: {
      week: "Monday - Friday: 9:00 - 18:00",
      saturday: "Saturday: 10:00 - 14:00"
    }
  }
};

const info = contactInfo[locale] || contactInfo.es;
---

<!DOCTYPE html>
<html lang={locale}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>{tKey('nav.contacts')} | EVITAX</title>
    <link rel="stylesheet" href="/src/styles/global.css">
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="header-content">
                <a href={`/${locale}`} class="logo">
<img src="/logo_evi_big.png" alt="EVITAX" style="height: 75px; width: auto;">
                </a>
                <nav class="nav">
                    <a href={`/${locale}`}>{tKey('nav.home')}</a>
                    <a href={`/services/${locale}`}>{tKey('nav.services')}</a>
                    <a href={`/team/${locale}`}>{tKey('nav.team')}</a>
                    <a href={`/contacts/${locale}`}>{tKey('nav.contacts')}</a>
                </nav>
                <div class="language-switcher">
                    <a href="/contacts/es" class={locale === 'es' ? 'active' : ''}>ES</a>
                    <a href="/contacts/ru" class={locale === 'ru' ? 'active' : ''}>RU</a>
                    <a href="/contacts/en" class={locale === 'en' ? 'active' : ''}>EN</a>
                </div>
            </div>
        </div>
    </header>

    <main>
        <section class="section">
            <div class="container">
                <h1 class="section-title">{tKey('nav.contacts')}</h1>
                
                <div class="contacts-tabs" id="contactsTabs">
                    <!-- Таб 1: Контактная информация -->
                    <div class="contact-tab-item">
                        <button class="contact-tab-button">
                            <span>📋 {locale === 'es' ? 'Información de Contacto' : locale === 'ru' ? 'Контактная информация' : 'Contact Information'}</span>
                            <span class="contact-tab-icon">▼</span>
                        </button>
                        <div class="contact-tab-content">
                            <div class="contact-info">
                                <p><strong>📍 {locale === 'es' ? 'Dirección' : locale === 'ru' ? 'Адрес' : 'Address'}:</strong><br>{info.address}</p>
                                <p><strong>📞 {locale === 'es' ? 'Teléfono' : locale === 'ru' ? 'Телефон' : 'Phone'}:</strong><br><a href={`tel:${info.phone}`}>{info.phone}</a></p>
                                <p><strong>✉️ Email:</strong><br><a href={`mailto:${info.email}`}>{info.email}</a></p>
                            </div>
                            
                            <div class="contact-schedule">
                                <h3>{locale === 'es' ? 'Horario de Atención' : locale === 'ru' ? 'Часы работы' : 'Business Hours'}</h3>
                                <p>{info.schedule.week}</p>
                                <p>{info.schedule.saturday}</p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Таб 2: Форма отправки сообщения -->
                    <div class="contact-tab-item">
                        <button class="contact-tab-button">
                            <span>✉️ {locale === 'es' ? 'Envíanos un Mensaje' : locale === 'ru' ? 'Отправьте нам сообщение' : 'Send us a Message'}</span>
                            <span class="contact-tab-icon">▼</span>
                        </button>
                        <div class="contact-tab-content">
                            <form id="contactForm" action="https://formspree.io/f/myklbazq" method="POST">
                                <div class="form-group">
                                    <label for="name">{locale === 'es' ? 'Nombre' : locale === 'ru' ? 'Имя' : 'Name'} *</label>
                                    <input type="text" id="name" name="name" required>
                                </div>
                                
                                <div class="form-group">
                                    <label for="email">Email *</label>
                                    <input type="email" id="email" name="email" required>
                                </div>
                                
                                <div class="form-group">
                                    <label for="phone">{locale === 'es' ? 'Teléfono' : locale === 'ru' ? 'Телефон' : 'Phone'}</label>
                                    <input type="tel" id="phone" name="phone">
                                </div>
                                
                                <div class="form-group">
                                    <label for="message">{locale === 'es' ? 'Mensaje' : locale === 'ru' ? 'Сообщение' : 'Message'} *</label>
                                    <textarea id="message" name="message" rows="5" required></textarea>
                                </div>
                                
                                <!-- Защита от спама -->
                                <input type="text" name="_gotcha" style="display:none">
                                
                                <div id="formStatus" class="form-status" style="display: none;"></div>
                                
                                <button type="submit" class="btn btn-primary" id="submitBtn">
                                    {locale === 'es' ? 'Enviar Mensaje' : locale === 'ru' ? 'Отправить сообщение' : 'Send Message'}
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>EVITAX</h3>
                    <p>{info.address}</p>
                    <p>📞 {info.phone}</p>
                    <p>✉️ {info.email}</p>
                </div>
                <div class="footer-section">
                    <h3>{tKey('nav.services')}</h3>
                    <p>✓ {locale === 'es' ? 'Asesoría Contable' : locale === 'ru' ? 'Бухгалтерский консалтинг' : 'Accounting Consulting'}</p>
                    <p>✓ {locale === 'es' ? 'Declaración de Impuestos' : locale === 'ru' ? 'Налоговые декларации' : 'Tax Returns'}</p>
                    <p>✓ {locale === 'es' ? 'Gestión Laboral' : locale === 'ru' ? 'Кадровый учет' : 'HR Management'}</p>
                </div>
                <div class="footer-section">
                    <h3>{locale === 'es' ? 'Horario' : locale === 'ru' ? 'Часы работы' : 'Schedule'}</h3>
                    <p>{info.schedule.week}</p>
                    <p>{info.schedule.saturday}</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 EVITAX. {tKey('footer.rights')}</p>
            </div>
        </div>
    </footer>

    <script>
        (function() {
            // Инициализация табов
            function initContactTabs() {
                var buttons = document.querySelectorAll('.contact-tab-button');
                for (var i = 0; i < buttons.length; i++) {
                    buttons[i].onclick = function() {
                        var tabItem = this.closest('.contact-tab-item');
                        var isActive = tabItem.classList.contains('active');
                        var allTabs = document.querySelectorAll('.contact-tab-item');
                        for (var j = 0; j < allTabs.length; j++) {
                            allTabs[j].classList.remove('active');
                        }
                        if (!isActive) {
                            tabItem.classList.add('active');
                        }
                    };
                }
                var firstTab = document.querySelector('.contact-tab-item');
                if (firstTab) {
                    firstTab.classList.add('active');
                }
            }
            
            // AJAX отправка формы
            function initForm() {
                var form = document.getElementById('contactForm');
                if (!form) return;
                
                var submitBtn = document.getElementById('submitBtn');
                var statusDiv = document.getElementById('formStatus');
                
                // Определяем язык для сообщений
                var locale = document.documentElement.lang || 'es';
                var messages = {
                    es: {
                        sending: 'Enviando...',
                        success: '✓ ¡Mensaje enviado con éxito! Nos pondremos en contacto contigo pronto.',
                        error: '✗ Error al enviar. Por favor, inténtalo de nuevo.',
                        connectionError: '✗ Error de conexión. Verifica tu internet.'
                    },
                    ru: {
                        sending: 'Отправка...',
                        success: '✓ Сообщение успешно отправлено! Мы свяжемся с вами в ближайшее время.',
                        error: '✗ Ошибка отправки. Пожалуйста, попробуйте снова.',
                        connectionError: '✗ Ошибка соединения. Проверьте интернет.'
                    },
                    en: {
                        sending: 'Sending...',
                        success: '✓ Message sent successfully! We will contact you soon.',
                        error: '✗ Error sending message. Please try again.',
                        connectionError: '✗ Connection error. Please check your internet.'
                    }
                };
                
                var t = messages[locale] || messages.es;
                
                form.onsubmit = async function(e) {
                    e.preventDefault();
                    
                    // Отключаем кнопку и показываем статус отправки
                    submitBtn.disabled = true;
                    var originalText = submitBtn.textContent;
                    submitBtn.textContent = t.sending;
                    statusDiv.style.display = 'block';
                    statusDiv.textContent = t.sending;
                    statusDiv.className = 'form-status sending';
                    
                    var formData = new FormData(form);
                    
                    try {
                        var response = await fetch(form.action, {
                            method: 'POST',
                            body: formData,
                            headers: { 'Accept': 'application/json' }
                        });
                        
                        if (response.ok) {
                            form.reset();
                            statusDiv.textContent = t.success;
                            statusDiv.className = 'form-status success';
                            
                            // Скрыть сообщение через 5 секунд
                            setTimeout(function() {
                                statusDiv.style.display = 'none';
                            }, 5000);
                        } else {
                            var errorData = await response.json();
                            statusDiv.textContent = t.error + (errorData.error ? ' ' + errorData.error : '');
                            statusDiv.className = 'form-status error';
                        }
                    } catch (error) {
                        console.error('Form submission error:', error);
                        statusDiv.textContent = t.connectionError;
                        statusDiv.className = 'form-status error';
                    } finally {
                        submitBtn.disabled = false;
                        submitBtn.textContent = originalText;
                    }
                };
            }
            
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() {
                    initContactTabs();
                    initForm();
                });
            } else {
                initContactTabs();
                initForm();
            }
        })();
    </script>
</body>
</html>