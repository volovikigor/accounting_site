{
  "rewrites": [
    {
      "source": "/",
      "destination": "/es"
    },
    {
      "source": "/([^/]+?)/?",
      "destination": "/$1/index.html"
    },
    {
      "source": "/services/([^/]+?)/?",
      "destination": "/services/$1/index.html"
    },
    {
      "source": "/team/([^/]+?)/?",
      "destination": "/team/$1/index.html"
    },
    {
      "source": "/contacts/([^/]+?)/?",
      "destination": "/contacts/$1/index.html"
    }
  ]
}