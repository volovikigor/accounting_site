---
// src/pages/services.astro
import { t, defaultLocale, locales } from '../i18n/index';
import { getCollection } from 'astro:content';

// Получаем язык из URL
const urlParams = Astro.url.searchParams;
let locale = urlParams.get('lang') || defaultLocale;

if (!locales.includes(locale as any)) {
  locale = defaultLocale;
}

const tKey = (key: string) => t(locale as any, key);

// Загружаем услуги для текущего языка
const collectionName = `services_${locale}`;
const services = await getCollection(collectionName);

// Отладка
console.log(`Current locale: ${locale}`);
console.log(`Collection name: ${collectionName}`);
console.log(`Services count: ${services.length}`);
---

<!DOCTYPE html>
<html lang={locale}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{tKey('nav.services')} | ContabilidadPro</title>
    <link rel="stylesheet" href="/src/styles/global.css">
</head>
<body>
    <header class="header">
        <div class="container">
            <div class="header-content">
                <a href={`/?lang=${locale}`} class="logo">📊 ContabilidadPro</a>
                <nav class="nav">
                    <a href={`/?lang=${locale}`}>{tKey('nav.home')}</a>
                    <a href={`/services?lang=${locale}`}>{tKey('nav.services')}</a>
                    <a href={`/team?lang=${locale}`}>{tKey('nav.team')}</a>
                    <a href={`/contacts?lang=${locale}`}>{tKey('nav.contacts')}</a>
                </nav>
                <div class="language-switcher">
                    <a href="/services?lang=es" class={locale === 'es' ? 'active' : ''}>ES</a>
                    <a href="/services?lang=ru" class={locale === 'ru' ? 'active' : ''}>RU</a>
                    <a href="/services?lang=en" class={locale === 'en' ? 'active' : ''}>EN</a>
                </div>
            </div>
        </div>
    </header>

    <main>
        <section class="section">
            <div class="container">
                <h1 class="section-title">{tKey('nav.services')}</h1>
                
                {services.length === 0 ? (
                    <div class="text-center">
                        <p>
                            {locale === 'es' && 'No hay servicios añadidos todavía.'}
                            {locale === 'ru' && 'Услуги пока не добавлены.'}
                            {locale === 'en' && 'No services added yet.'}
                        </p>
                        <p><a href="/admin">Panel de administración</a></p>
                    </div>
                ) : (
                    <div class="services-grid">
                        {services.map((service) => (
                            <div class="service-card" key={service.id}>
                                {service.data.image && (
                                    <img 
                                        src={service.data.image} 
                                        alt={service.data.title}
                                        style="width: 100%; height: 200px; object-fit: cover; border-radius: 8px; margin-bottom: 1rem;"
                                    />
                                )}
                                <h3>{service.data.title}</h3>
                                {service.data.price && (
                                    <div class="service-price">{service.data.price}</div>
                                )}
                                <div class="service-description" set:html={service.rendered?.body || service.body} />
                            </div>
                        ))}
                    </div>
                )}
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>ContabilidadPro</h3>
                    <p>{tKey('footer.address')}</p>
                    <p>📞 {tKey('footer.phone')}</p>
                    <p>✉️ {tKey('footer.email')}</p>
                </div>
                <div class="footer-section">
                    <h3>{tKey('nav.services')}</h3>
                    <p>✓ {locale === 'es' ? 'Asesoría Contable' : locale === 'ru' ? 'Бухгалтерский консалтинг' : 'Accounting Consulting'}</p>
                    <p>✓ {locale === 'es' ? 'Declaración de Impuestos' : locale === 'ru' ? 'Налоговые декларации' : 'Tax Returns'}</p>
                    <p>✓ {locale === 'es' ? 'Gestión Laboral' : locale === 'ru' ? 'Кадровый учет' : 'HR Management'}</p>
                </div>
                <div class="footer-section">
                    <h3>{locale === 'es' ? 'Horario' : locale === 'ru' ? 'Часы работы' : 'Schedule'}</h3>
                    <p>{locale === 'es' ? 'Lunes - Viernes: 9:00 - 18:00' : locale === 'ru' ? 'Пн - Пт: 9:00 - 18:00' : 'Mon - Fri: 9:00 - 18:00'}</p>
                    <p>{locale === 'es' ? 'Sábado: 10:00 - 14:00' : locale === 'ru' ? 'Сб: 10:00 - 14:00' : 'Sat: 10:00 - 14:00'}</p>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 ContabilidadPro. {tKey('footer.rights')}</p>
            </div>
        </div>
    </footer>
</body>
</html>